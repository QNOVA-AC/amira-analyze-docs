{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "InsightFlow",
  "favicon": "/favicon.png",
  "colors": {
    "primary": "#6366F1",
    "light": "#818CF8",
    "dark": "#4F46E5"
  },
  "logo": {
    "light": "https://insightflow-prod-assets.s3.eu-central-1.amazonaws.com/insightflow-logo.png",
    "dark": "https://insightflow-prod-assets.s3.eu-central-1.amazonaws.com/insightflow-logo.png"
  },
  "font": {
    "heading": "Inter",
    "body": "Inter",
    "code": "JetBrains Mono"
  },
  "appearance": {
    "default": "system"
  },
  "search": {
    "placeholder": "Search API endpoints..."
  },
  "openapi": ["/api-reference/openapi.json"],
  "api": {
    "baseUrl": "https://api.staging.insightflow.studio",
    "auth": {
      "method": "key",
      "name": "X-API-Key"
    },
    "playground": {
      "mode": "show"
    }
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true,
    "raiseIssue": true
  },
